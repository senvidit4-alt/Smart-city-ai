# Copy this file to .env and fill in your actual keys
# Never commit .env — it is gitignored

# Required: Google Gemini API key (fallback model)
GOOGLE_API_KEY=your_google_api_key_here

# Required: Groq API key (primary model — Qwen3-32B)
GROQ_API_KEY=your_groq_api_key_here

# Optional: OpenWeatherMap API key for live weather tool
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Optional: Model configuration
GOOGLE_GEMINI_MODEL=gemini-2.0-flash
GOOGLE_GEMINI_MODEL_FALLBACKS=gemini-1.5-flash,gemini-1.5-flash-8b
AGENT_INVOKE_TIMEOUT_SEC=150
